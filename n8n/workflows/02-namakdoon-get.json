            },
            {
              "id": "g2",
              "name": "slug",
              "value": "={{ $json.query?.slug || $json.slug || '' }}",
              "type": "string"
            }
          ]
        },
        "options": {}
      },
      "id": "get-prepare",
      "name": "Prepare Query",
      "type": "n8n-nodes-base.set",
