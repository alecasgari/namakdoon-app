  "connections": {
    "Webhook": {
      "main": [[{ "node": "Prepare Query", "type": "main", "index": 0 }]]
    },
    "Prepare Query": {
      "main": [[{ "node": "Has Slug?", "type": "main", "index": 0 }]]
    },
    "Has Slug?": {
