    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict",
            "version": 2
          },
          "conditions": [
            {
              "id": "slug-found",
              "leftValue": "={{ $json.id }}",
              "rightValue": "",
              "operator": {
                "type": "string",
                "operation": "notEmpty",
                "singleValue": true
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "get-slug-found",
      "name": "Slug Found?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [1100, 180]
    },
    {
      "parameters": {
        "operation": "get",
        "dataTableId": {
          "__rl": true,
          "mode": "name",
          "value": "namakdoon_recipes"
        },
        "matchType": "allConditions",
        "filters": {
          "conditions": [
            {
              "keyName": "id",
              "condition": "eq",
              "keyValue": "={{ $('Prepare Query').item.json.id || $('Prepare Query').item.json.slug }}"
            }
          ]
        },
        "returnAll": false,
        "limit": 1
      },
      "id": "get-by-id",
      "name": "Get ById",
      "type": "n8n-nodes-base.dataTable",
      "typeVersion": 1.1,
      "position": [880, 420],
      "alwaysOutputData": true
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ $json.id ? { \"recipe\": $json } : { \"error\": \"دستور پیدا نشد\" } }}",
        "options": {
          "responseCode": "={{ $json.id ? 200 : 404 }}",
          "responseHeaders": {
            "entries": [
              {
                "name": "Access-Control-Allow-Origin",
                "value": "*"
              }
            ]
          }
        }
      },
      "id": "get-respond",
      "name": "Respond",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1.1,
      "position": [1340, 300]
    }
