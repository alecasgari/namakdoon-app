          "mode": "name",
          "value": "namakdoon_recipes"
        },
        "matchType": "allConditions",
        "filters": {
          "conditions": [
            {
              "keyName": "slug",
              "condition": "eq",
              "keyValue": "={{ $json.slug }}"
            }
          ]
        },
        "returnAll": false,
        "limit": 1
      },
      "id": "get-by-slug",
      "name": "Get BySlug",
      "type": "n8n-nodes-base.dataTable",
      "typeVersion": 1.1,
      "position": [880, 180],
      "alwaysOutputData": true
