              "id": "c-audio",
              "leftValue": "={{ $json.hasAudio }}",
              "rightValue": true,
              "operator": { "type": "boolean", "operation": "true", "singleValue": true }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "create-has-audio",
      "name": "Has Audio?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [1100, 380]
    },
    {
      "parameters": {
        "resource": "audio",
        "operation": "analyze",
        "modelId": { "__rl": true, "mode": "id", "value": "models/gemini-flash-lite-latest" },
        "text": "این فایل صوتی را کامل به متن فارسی پیاده‌سازی کن. اگر محتوا انگلیسی بود، به فارسی برگردان. فقط متن گفت‌وگو یا دستور را برگردان.",
        "inputType": "binary",
        "binaryPropertyName": "audio",
        "simplify": true,
        "options": { "maxOutputTokens": 4096 }
      },
      "id": "create-analyze",
      "name": "Analyze Audio",
      "type": "@n8n/n8n-nodes-langchain.googleGemini",
      "typeVersion": 1.1,
      "position": [1340, 280],
      "credentials": {
        "googlePalmApi": {
          "id": "REPLACE_WITH_YOUR_GEMINI_CREDENTIAL_ID",
          "name": "Google Gemini account"
        }
      }
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "s1",
              "name": "sourceText",
              "value": "={{ [$('Prepare Input').item.json.text, ($json.content?.parts?.[0]?.text || $json.mergedResponse || '')].filter(Boolean).join('\\n\\n') }}",
              "type": "string"
            }
          ]
        },
        "options": {}
      },
      "id": "create-text-from-audio",
