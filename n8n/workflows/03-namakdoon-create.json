              "value": "={{ $json.text || $json.body?.text || '' }}",
              "type": "string"
            },
            {
              "id": "a4",
              "name": "hasAudio",
              "value": "={{ !!$binary?.audio }}",
              "type": "boolean"
            },
            {
              "id": "a5",
              "name": "raw",
              "value": "={{ $json.body || $json }}",
              "type": "object"
            }
          ]
        },
        "includeOtherFields": true,
        "options": { "includeBinary": true }
