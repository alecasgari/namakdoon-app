            { "id": "r11", "name": "tips", "value": "={{ $json.parsed.tips || '' }}", "type": "string" },
            { "id": "r12", "name": "calories", "value": "={{ Number($json.parsed.calories) || 0 }}", "type": "number" },
            { "id": "r13", "name": "difficulty", "value": "={{ $json.parsed.difficulty || 'متوسط' }}", "type": "string" },
            { "id": "r14", "name": "image_url", "value": "", "type": "string" },
            { "id": "r15", "name": "video_url", "value": "", "type": "string" }
          ]
