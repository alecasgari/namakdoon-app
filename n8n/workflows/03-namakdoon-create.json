    {
      "parameters": {
        "resource": "text",
        "operation": "message",
        "modelId": { "__rl": true, "mode": "id", "value": "models/gemini-flash-lite-latest" },
        "messages": {
          "values": [
            {
              "content": "=تو یک استخراج‌کننده دستور آشپزی هستی. متن زیر را به یک دستور کامل و مرتب فارسی تبدیل کن. اگر متن انگلیسی بود همه فیلدها را فارسی برگردان. فقط JSON معتبر برگردان با ساختار زیر و هیچ متن دیگری ننویس:\n{\n  \"slug\": \"english-kebab-case\",\n  \"title\": \"\",\n  \"description\": \"\",\n  \"ingredients\": [{\"name\":\"\",\"amount\":1,\"unit\":\"\",\"note\":\"\"}],\n  \"steps\": [{\"text\":\"\"}],\n  \"prep_time\": 0,\n  \"cook_time\": 0,\n  \"servings_base\": 4,\n  \"meal_type\": \"ناهار\",\n  \"tags\": [\"\"],\n  \"tips\": \"\",\n  \"calories\": 0,\n  \"difficulty\": \"متوسط\"\n}\nقوانین:\n- amount حتما عدد باشد تا بعداً مقیاس شود\n- difficulty یکی از: آسان، متوسط، سخت\n- servings_base اگر مشخص نبود 4 بگذار\n\nمتن ورودی:\n{{ $json.sourceText }}",
              "role": "user"
            }
          ]
        },
        "simplify": true,
        "jsonOutput": true,
        "options": {}
      },
      "id": "create-structure",
      "name": "Structure Recipe",
      "type": "@n8n/n8n-nodes-langchain.googleGemini",
      "typeVersion": 1.1,
      "position": [1800, 360],
      "credentials": {
        "googlePalmApi": {
          "id": "REPLACE_WITH_YOUR_GEMINI_CREDENTIAL_ID",
