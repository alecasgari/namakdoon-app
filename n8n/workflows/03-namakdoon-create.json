      "typeVersion": 2.2,
      "position": [860, 280]
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            { "id": "p1", "name": "slug", "value": "={{ $json.raw.slug || ('recipe-' + Date.now()) }}", "type": "string" },
            { "id": "p2", "name": "title", "value": "={{ $json.raw.title }}", "type": "string" },
            { "id": "p3", "name": "description", "value": "={{ $json.raw.description || '' }}", "type": "string" },
            { "id": "p4", "name": "ingredients", "value": "={{ typeof $json.raw.ingredients === 'string' ? $json.raw.ingredients : JSON.stringify($json.raw.ingredients || []) }}", "type": "string" },
            { "id": "p5", "name": "steps", "value": "={{ typeof $json.raw.steps === 'string' ? $json.raw.steps : JSON.stringify($json.raw.steps || []) }}", "type": "string" },
            { "id": "p6", "name": "prep_time", "value": "={{ Number($json.raw.prep_time) || 0 }}", "type": "number" },
            { "id": "p7", "name": "cook_time", "value": "={{ Number($json.raw.cook_time) || 0 }}", "type": "number" },
            { "id": "p8", "name": "servings_base", "value": "={{ Number($json.raw.servings_base) || 4 }}", "type": "number" },
            { "id": "p9", "name": "meal_type", "value": "={{ $json.raw.meal_type || '' }}", "type": "string" },
            { "id": "p10", "name": "tags", "value": "={{ typeof $json.raw.tags === 'string' ? $json.raw.tags : JSON.stringify($json.raw.tags || []) }}", "type": "string" },
            { "id": "p11", "name": "tips", "value": "={{ $json.raw.tips || '' }}", "type": "string" },
            { "id": "p12", "name": "calories", "value": "={{ Number($json.raw.calories) || 0 }}", "type": "number" },
            { "id": "p13", "name": "difficulty", "value": "={{ $json.raw.difficulty || 'متوسط' }}", "type": "string" },
            { "id": "p14", "name": "image_url", "value": "={{ $json.raw.image_url || '' }}", "type": "string" },
            { "id": "p15", "name": "video_url", "value": "={{ $json.raw.video_url || '' }}", "type": "string" }
          ]
        },
        "options": {}
      },
      "id": "create-map-publish",
